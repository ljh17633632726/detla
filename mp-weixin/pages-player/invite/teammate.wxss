.invite-page.data-v-e09f31ee {
  background: #ffffff;
  min-height: 100vh;
}
.search-bar.data-v-e09f31ee {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #f1f5f9;
}
.search-bar .search-input.data-v-e09f31ee {
  flex: 1;
  background: #e2e8f0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}
.search-bar .search-btn.data-v-e09f31ee {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #ff4544, #e63939, #e63939);
  color: #ffffff;
  font-weight: bold;
  border-radius: 999rpx;
  font-size: 26rpx;
}
.list.data-v-e09f31ee {
  height: calc(100vh - 120rpx);
  padding: 20rpx 24rpx;
}
.player-card.data-v-e09f31ee {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.player-card .avatar.data-v-e09f31ee {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.player-card .info.data-v-e09f31ee {
  flex: 1;
}
.player-card .info .name.data-v-e09f31ee {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}
.player-card .info .tags.data-v-e09f31ee {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.player-card .info .tag.data-v-e09f31ee {
  font-size: 22rpx;
  color: #64748b;
