  font-size: 26rpx;
  border-radius: 999rpx;
}
.loading-tip.data-v-e09f31ee {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 分成弹窗 */
.modal-mask.data-v-e09f31ee {
