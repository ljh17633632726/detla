.qr-page.data-v-7c88b6cc {
  background: #ffffff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.qr-list.data-v-7c88b6cc {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}
.qr-item.data-v-7c88b6cc {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}
.qr-content.data-v-7c88b6cc {
