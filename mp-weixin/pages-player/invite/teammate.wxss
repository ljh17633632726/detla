}
.player-card .info .tag.tag-warn.data-v-e09f31ee {
  color: #ee0a24;
  background: rgba(238, 10, 36, 0.1);
}
.player-card .invite-btn.data-v-e09f31ee {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #ff4544, #e63939, #e63939);
