  font-weight: bold;
  color: #ff4544;
}
.logo-area .subtitle.data-v-d08ef7d4 {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}
.tab-bar.data-v-d08ef7d4 {
  display: flex;
  width: 100%;
  margin-bottom: 60rpx;
  border-bottom: 2rpx solid #e2e8f0;
  position: relative;
  z-index: 1;
}
.tab-bar .tab-item.data-v-d08ef7d4 {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #94a3b8;
  padding-bottom: 20rpx;
  position: relative;
  transition: color 0.2s;
}
.tab-bar .tab-item.active.data-v-d08ef7d4 {
  color: #ff4544;
  font-weight: bold;
}
.tab-bar .tab-item.active.data-v-d08ef7d4::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #ff4544, #e63939);
  border-radius: 2rpx;
}
