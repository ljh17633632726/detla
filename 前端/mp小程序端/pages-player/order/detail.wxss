.progress-item.data-v-bb34d8c7 {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}
.progress-item .p-content.data-v-bb34d8c7 {
  font-size: 26rpx;
  color: #1e293b;
  display: block;
}
.progress-item .p-time.data-v-bb34d8c7 {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 6rpx;
}
.progress-item .p-images.data-v-bb34d8c7 {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.progress-item .p-img.data-v-bb34d8c7 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}
.actions.data-v-bb34d8c7 {
  display: flex;
  gap: 20rpx;
  padding: 40rpx 24rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.btn.data-v-bb34d8c7 {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #ff4544, #e63939);
  color: #ffffff;
  font-weight: bold;
  font-size: 28rpx;
  border-radius: 999rpx;
}
.btn.btn-success.data-v-bb34d8c7 {
  background: linear-gradient(135deg, #07c160, #06ad56);
}
.btn-ghost.data-v-bb34d8c7 {
  padding: 16rpx 40rpx;
  border: 1rpx solid rgba(255, 69, 68, 0.4);
  color: #ff4544;
  font-size: 28rpx;
  border-radius: 999rpx;
}
.btn-warn.data-v-bb34d8c7 {
  padding: 16rpx 40rpx;
  border: 1rpx solid rgba(238, 10, 36, 0.4);
  color: #ee0a24;
  font-size: 28rpx;
  border-radius: 999rpx;
}
.user-row.data-v-bb34d8c7 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.user-row .u-avatar.data-v-bb34d8c7 {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #f1f5f9;
}
.user-row .u-name.data-v-bb34d8c7 {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

/* 换人弹窗 */
.modal-mask.data-v-bb34d8c7 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box.data-v-bb34d8c7 {
  width: 85%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  border: 1rpx solid #e2e8f0;
}
.modal-title.data-v-bb34d8c7 {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  text-align: center;
