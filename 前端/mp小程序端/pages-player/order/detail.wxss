  color: #ee0a24;
  font-weight: bold;
}
.income-hint.data-v-bb34d8c7 {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  display: block;
}
.teammate-row.data-v-bb34d8c7 {
  display: flex;
  align-items: center;
  gap: 12rpx;
