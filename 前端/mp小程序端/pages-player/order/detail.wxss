.detail.data-v-bb34d8c7 {
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}
.status-bar.data-v-bb34d8c7 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.status-bar .status-right.data-v-bb34d8c7 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.status-bar .order-no.data-v-bb34d8c7 {
  font-size: 24rpx;
  color: #94a3b8;
}
.card.data-v-bb34d8c7 {
  margin: 20rpx 24rpx 0;
  padding: 28rpx 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.card-header.data-v-bb34d8c7 {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.title-bar.data-v-bb34d8c7 {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #ff4544, #e63939);
  margin-right: 12rpx;
}
.card-title.data-v-bb34d8c7 {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
}
.copy-link.data-v-bb34d8c7 {
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  color: #ff4544;
  border: 1rpx solid rgba(255, 69, 68, 0.28);
  border-radius: 999rpx;
  flex-shrink: 0;
}
.row-copy-link.data-v-bb34d8c7 {
  padding: 6rpx 16rpx;
  font-size: 20rpx;
}
.info-row.data-v-bb34d8c7 {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.info-row .label.data-v-bb34d8c7 {
  font-size: 26rpx;
  color: #94a3b8;
  width: 140rpx;
  flex-shrink: 0;
}
.info-row .value.data-v-bb34d8c7 {
  font-size: 26rpx;
  color: #1e293b;
