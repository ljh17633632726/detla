.modal-btns.data-v-c81956d8 {
  display: flex;
  gap: 24rpx;
}
.modal-btn.data-v-c81956d8 {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
}
.modal-btn.cancel.data-v-c81956d8 {
  background: rgba(0, 0, 0, 0.05);
  color: rgba(0, 0, 0, 0.55);
